{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "height": 40,
  "margin-left": 15,
  "margin-top": 8,
  "margin-right": 15,
  "spacing": 5,

  // --- MÓDULOS DE LA IZQUIERDA ---
  "modules-left": [
    "clock#date",
    "clock",
    "custom/michi_player",
    "custom/music"
  ],

  // --- CENTRO LIMPIO (Sin logo de Arch) ---
  "modules-center": [],

  // --- MÓDULOS DE LA DERECHA ---
  "modules-right": [
    "tray",
    "cpu",
    "memory",
    "pulseaudio",
    "network",
    "battery",
    "custom/power"
  ],

  // --- CONFIGURACIÓN DE LOS MÓDULOS ---

  // NUEVO: Módulo del Michi Player
  "custom/michi_player": {
    "format": "{}",
    "exec": "echo '󰄛'",
    "interval": "once",
    "on-click": "bash ~/.config/waybar/scripts/michi_player.sh",
    "tooltip": true,
    "tooltip-format": "Reproductor FLAC"
  },

  // 1. Reloj de la HORA (12h, am/pm minúscula, sin íconos)
  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip": false
  },

  // 2. Reloj de la FECHA (Click para calendario, sin íconos)
// 2. Reloj de la FECHA (Click para calendario, sin íconos)
  "clock#date": {
    "locale": "es_MX.UTF-8",
    "format": "{:%a, %d %b}", 
    "tooltip": false,
    "on-click": "eww open calendar --toggle" 
  },
  "custom/music": {
    "format": "{}",
    "exec": "playerctl metadata --format '{{title}}' 2>/dev/null",
    "on-click": "agsv1 -t reproductor", 
    "interval": 3,
    "max-length": 25
  },

  "network": {
    "format-wifi": "󰖩 {essid}",
    "format-disconnected": "󰖪 Off",
    "on-click": "nm-connection-editor"
  },

  "cpu": { "format": " {usage}%" },

  "memory": { "format": " {percentage}%" },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-icons": { "default": ["", "", ""] },
    "on-click": "pavucontrol"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": ["", "", "", "", ""]
  },

  "custom/power": {
    "format": "󰐥",
    "on-click": "~/.config/hypr/scripts/quick-menu.sh"
  }
}
